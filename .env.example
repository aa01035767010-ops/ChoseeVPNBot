# Telegram Bot Settings
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Express Server Settings
PORT=3000

# 3X-UI Panel Settings (VPS)
# Set these to connect to your real VPS with 3X-UI installed
XUI_PANEL_URL=http://your_vps_ip:2053
XUI_USERNAME=admin
XUI_PASSWORD=password
XUI_INBOUND_ID=1

# Environment Mode
# Set to 'true' to run locally in simulation/mock mode without connecting to a real VPS.
# Set to 'false' to connect to your actual 3X-UI VPS panel.
MOCK_MODE=true
